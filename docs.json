{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Sentinel",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "quickstart",
          "docs/getting-started/installation",
          "docs/getting-started/concepts"
        ]
      },
      {
        "group": "Marketplace",
        "pages": [
          "docs/marketplace/discover",
          "docs/marketplace/trust-reports",
          "docs/marketplace/playground"
        ]
      },
      {
        "group": "For Developers",
        "pages": [
          "docs/developers/register",
          "docs/developers/publish",
          "docs/developers/manifest",
          "docs/developers/pricing",
          "docs/sdk/cli"
        ]
      },
      {
        "group": "API Reference",
        "pages": [
          "docs/api-reference/authentication",
          "docs/api-reference/agents",
          "docs/api-reference/billing"
        ]
      },
      {
        "group": "Trust & Verification",
        "pages": [
          "docs/trust/verification-process",
          "docs/trust/trust-scores",
          "docs/trust/badges"
        ]
      },
      {
        "group": "SDKs",
        "pages": [
          "docs/sdk/python",
          "docs/sdk/typescript"
        ]
      },
      {
        "group": "MCP Integration",
        "pages": [
          "docs/mcp/overview",
          "docs/mcp/a2a"
        ]
      },
      {
        "group": "Compliance",
        "pages": [
          "docs/compliance/dpdp",
          "docs/compliance/security"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API Reference",
          "href": "/docs/api-reference/authentication",
          "icon": "code"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/sentinel-network",
          "icon": "github"
        },
        {
          "anchor": "Status",
          "href": "https://status.sentinel.network",
          "icon": "signal"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@sentinel.network"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Developer Dashboard",
      "href": "https://app.sentinel.network"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/sentinel_network",
      "github": "https://github.com/sentinel-network",
      "linkedin": "https://linkedin.com/company/sentinel-network"
    }
  }
}
